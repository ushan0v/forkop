#!/usr/bin/ucode

let fs = require("fs");

function as_string(value) {
    return value == null ? "" : "" + value;
}

const CONFIG_NAME = getenv("PODKOP_CONFIG_NAME") || "podkop-plus";
const LIB_DIR = getenv("PODKOP_LIB") || "/usr/lib/podkop-plus";
const BIN_PATH = getenv("PODKOP_BIN") || "/usr/bin/podkop-plus";
const SERVICE_INIT = getenv("PODKOP_SERVICE_INIT") || "/etc/init.d/podkop-plus";

function shell_quote(value) {
    return "'" + replace(as_string(value), /'/g, "'\\''") + "'";
}

function command_from_args(args) {
    let parts = [];
    for (let arg in args)
        push(parts, shell_quote(arg));
    return join(" ", parts);
}

function normalize_status(status) {
    status = int(status);
    return status > 255 ? int(status / 256) : status;
}

function module_path(path) {
    return LIB_DIR + "/" + as_string(path);
}

function file_readable(path) {
    return fs.stat(as_string(path)) != null;
}

function restore_dnsmasq_failsafe() {
    let module = module_path("dns/apply.uc");
    if (!file_readable(module))
        return;
    system(command_from_args([ "ucode", "-L", LIB_DIR, module, "failsafe-restore" ]) + " >/dev/null 2>&1");
}

function restore_dnsmasq_failsafe_on_loader_failure(command) {
    command = as_string(command);
    if (command == "start" || command == "stop" || command == "restart" ||
        command == "reload" || command == "uninstall" ||
        command == "dnsmasq_restore" || command == "restore_dnsmasq")
        restore_dnsmasq_failsafe();
}

function show_help() {
    print("Usage: ", BIN_PATH, " COMMAND\n\n");
    print("Available commands:\n");
    print("    start                   Start Podkop Plus service\n");
    print("    stop                    Stop Podkop Plus service\n");
    print("    reload                  Reload Podkop Plus configuration\n");
    print("    restart                 Restart Podkop Plus service\n");
    print("    enable                  Enable Podkop Plus autostart\n");
    print("    disable                 Disable Podkop Plus autostart\n");
    print("    uninstall               Remove Podkop Plus files installed outside opkg/apk\n");
    print("    main                    Run main Podkop Plus process\n");
    print("    list_update             Update remote lists\n");
    print("    list_update_if_due      Update remote lists only when the configured interval has elapsed\n");
    print("    subscription_update [rule] [source_index]\n");
    print("                            Update all subscription proxies, one rule, or one source in a rule\n");
    print("    subscription_update_async [rule] [source_index]\n");
    print("                            Start forced subscription update in the background\n");
    print("    subscription_update_status [job_id]\n");
    print("                            Get background subscription update status\n");
    print("    subscription_update_if_due\n");
    print("                            Update subscription proxies only when per-rule intervals have elapsed\n");
    print("    check_proxy             Check proxy connectivity\n");
    print("    check_nft               Check NFT rules\n");
    print("    check_nft_rules         Check NFT rules status\n");
    print("    check_sing_box          Check sing-box installation and status\n");
    print("    check_inbounds_config   Check whether enabled server inbounds are configured\n");
    print("    check_inbounds          Check server inbounds from the Servers tab\n");
    print("    check_logs              Show Podkop Plus logs from system journal\n");
    print("    check_sing_box_logs     Show sing-box logs\n");
    print("    check_fakeip            Test sing-box FakeIP DNS\n");
    print("    check_zapret_runtime    Check external zapret provider state\n");
    print("    check_zapret2_runtime   Check external zapret2 provider state\n");
    print("    check_byedpi_runtime    Check external ByeDPI provider state\n");
    print("    neutralize_zapret_defaults\n");
    print("                            Compatibility no-op; Podkop Plus does not manage standalone zapret\n");
    print("    clash_api               Clash API interface for managing proxies and groups\n");
    print("    show_config             Display current Podkop Plus configuration\n");
    print("    show_version            Show Podkop Plus version\n");
    print("    show_sing_box_config    Show sing-box configuration\n");
    print("    show_sing_box_version   Show sing-box version\n");
    print("    get_status              Get Podkop Plus service status\n");
    print("    get_outbound_link       Get source proxy link for a generated outbound\n");
    print("    get_outbound_metadata   Get generated outbound display names and countries\n");
    print("    get_subscription_metadata\n");
    print("                            Get UI-only metadata for a subscription rule\n");
    print("    get_sing_box_status     Get sing-box service status\n");
    print("    get_zapret_status       Get zapret provider and Podkop Plus-managed nfqws status\n");
    print("    get_zapret2_status      Get zapret2 provider and Podkop Plus-managed nfqws2 status\n");
    print("    get_byedpi_status       Get ByeDPI provider and Podkop Plus-managed ciadpi status\n");
    print("    get_system_info         Get system information in JSON format\n");
    print("    get_server_capabilities Get server UI capabilities in JSON format\n");
    print("    get_ui_capabilities     Get lightweight UI capabilities in JSON format\n");
    print("    get_ui_state            Get lightweight UI service/action state in JSON format\n");
    print("    service_action_async    Start a service action in the background\n");
    print("    service_action_status   Get background service action status\n");
    print("    latency_test_async      Start a dashboard latency test in the background\n");
    print("    latency_test_status     Get background latency test status\n");
    print("    ui_action_ack           Acknowledge a finished UI action state\n");
    print("    generate_reality_keypair\n");
    print("                            Generate a sing-box Reality key pair in JSON format\n");
    print("    get_tls_certificate_sha256 [server]\n");
    print("                            Get a server TLS certificate SHA-256 fingerprint in JSON format\n");
    print("    component_action        Manage Podkop Plus, sing-box, zapret, zapret2, and ByeDPI components\n");
    print("    component_action_async  Start a component action in the background\n");
    print("    component_action_status Get background component action status\n");
    print("    check_dns_available     Check DNS server availability\n");
    print("    global_check            Run global system check\n");
    print("    validate_nfqws_strategy_json\n");
    print("                            Validate an NFQWS strategy and print JSON result\n");
    print("    validate_nfqws2_strategy_json\n");
    print("                            Validate an NFQWS2 strategy and print JSON result\n");
    print("    validate_byedpi_strategy_json\n");
    print("                            Validate a ByeDPI ciadpi strategy and print JSON result\n");
}

