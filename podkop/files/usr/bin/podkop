function run_spec(command, spec, user_args) {
    let module = module_path(spec[0]);
    if (!file_readable(module)) {
        warn("Error: required file '", module, "' is missing or not readable\n");
        restore_dnsmasq_failsafe_on_loader_failure(command);
        return 1;
    }

    let args = [ "ucode", "-L", LIB_DIR, module, spec[1] ];
    let count = int(spec[2] || 0);
    for (let i = 0; i < count; i++)
        push(args, user_args[i] || "");

    return normalize_status(system(command_from_args(args)));
}

function main() {
    let command = ARGV[0] || "";
    let spec = command_spec(command);
    if (spec == null) {
        show_help();
        return 1;
    }

    let user_args = [];
    for (let i = 1; i < length(ARGV); i++)
        push(user_args, ARGV[i]);

    return run_spec(command, spec, user_args);
}

exit(main());
