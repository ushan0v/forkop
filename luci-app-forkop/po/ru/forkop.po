msgstr "Использовать другую секцию как промежуточный узел подключения к серверам этой секции. Не применяется к сетевым интерфейсам и JSON outbound."

msgid "Use CIDR prefixes like 192.168.1.0/24 or 2001:db8::/32"
msgstr "Используйте CIDR-префиксы, например 192.168.1.0/24 или 2001:db8::/32"

msgid "Use CIDR prefixes or IP addresses like 192.168.1.0/24, 192.168.1.10, or 2001:db8::1"
msgstr "Используйте CIDR-префиксы или IP-адреса, например 192.168.1.0/24, 192.168.1.10 или 2001:db8::1"

msgid "Use letters, digits, dots, underscores, or hyphens"
msgstr "Используйте буквы, цифры, точки, подчёркивания или дефисы"

msgid "Use sing-box duration format like 10s, 1m or 2m30s"
msgstr "Используйте формат длительности sing-box, например 10s, 1m или 2m30s"

msgid "Use sing-box duration format like 1d, 12h or 30m"
msgstr "Используйте формат длительности sing-box, например 1d, 12h или 30m"

msgid "Used by"
msgstr "Используется"

