msgstr "Настройки URLTest"

msgid "Use 32 hex characters"
msgstr "Укажите 32 hex-символа"

msgid "Use a domain name or IP address"
msgstr "Используйте доменное имя или IP-адрес"

msgid "Use a duration like 30s, 5m, or 1h30m"
msgstr "Укажите длительность в формате 30s, 5m или 1h30m"

msgid "Use a non-negative integer"
msgstr "Используйте неотрицательное целое число"

msgid "Use a non-zero secret"
msgstr "Укажите ненулевой секрет"

msgid "Use an HTTP or HTTPS URL"
msgstr "Укажите HTTP или HTTPS URL"

