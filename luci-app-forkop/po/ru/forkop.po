msgid "URL must use one of the following protocols:"
msgstr "URL должен использовать один из следующих протоколов:"

msgid "URL used to check whether a server is alive"
msgstr "URL, который используется для проверки, что сервер жив"

msgid "URL used to test server latency"
msgstr "URL который будет использоваться для тестирования задержки серверов"

msgid "URLTest"
msgstr "URLTest"

